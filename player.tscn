[sub_resource type="GDScript" id="GDScript_vkktu"]
script/source = "extends CharacterBody2D


@export var base_push_force: float = 200.0 :
	set(value):
		push_force = clamp(value, 0, 400)
		print(value)
@export var SPEED = 300.0
@export var JUMP_VELOCITY = -500.0 
@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D
@onready var collision_shape_2d: CollisionShape2D = $CollisionShape2D
@onready var audio_stream_jump: AudioStreamPlayer2D = $AudioStreamJump
@onready var audio_stream_up: AudioStreamPlayer2D = $AudioStreamUp
@onready var audio_stream_down: AudioStreamPlayer2D = $AudioStreamDown


var base_shape_radius: float
var base_shape_height: float
var push_force:float = base_push_force

func _ready() -> void:
	# Avoid modifying shape directly
	collision_shape_2d.shape = collision_shape_2d.shape.duplicate()
	
	base_shape_radius = collision_shape_2d.shape.radius
	base_shape_height = collision_shape_2d.shape.height
	
func _physics_process(delta: float) -> void:
	
	#if is_on_floor():
		#print(get_platform_velocity())
	
	# Add animation 
	if velocity.x > 1 or velocity.x < -1 : 
		animated_sprite_2d.animation = \"run\"
	else : 
		animated_sprite_2d.animation = \"idle\"
	# Add the gravity
	if not is_on_floor():
		velocity += get_gravity() * delta
		animated_sprite_2d.animation = \"jump\"
	
	if GameState.energy > 0 :
		if Input.is_action_pressed(\"scale up\") :
			GameState.player_scale += 0.1
			
			animated_sprite_2d.scale.x = GameState.player_scale
			animated_sprite_2d.scale.y = GameState.player_scale
			update_collision_size()

			push_force = base_push_force * GameState.player_scale
			if not audio_stream_up.playing:
				audio_stream_up.play()
			
		elif Input.is_action_pressed(\"scale down\") :
			GameState.player_scale -= 0.1
			
			animated_sprite_2d.scale.x = GameState.player_scale
			animated_sprite_2d.scale.y = GameState.player_scale
			update_collision_size()

			push_force = base_push_force * GameState.player_scale
			if not audio_stream_down.playing:
				audio_stream_down.play()
		
	# Handle jump.
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = clamp(JUMP_VELOCITY / GameState.player_scale, -500 , 0)
		audio_stream_jump.play()
		
	# Get the input direction and handle the movement/deceleration.
	# As good practice, you should replace UI actions with custom gameplay actions.
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	if direction:
		velocity.x = direction * SPEED / GameState.player_scale
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED / GameState.player_scale)

	velocity.x = clamp(velocity.x, -300 ,300)
	
	move_and_slide()
	
	if direction == 1.0 : 
		animated_sprite_2d.flip_h = false 
	elif direction == -1.0 : 
		animated_sprite_2d.flip_h = true 
	push_rigid_bodies()

func update_collision_size() -> void:
	collision_shape_2d.shape.radius = base_shape_radius * GameState.player_scale
	collision_shape_2d.shape.height = base_shape_height * GameState.player_scale
	
func push_rigid_bodies() -> void:
	for i in get_slide_collision_count():
		var collision := get_slide_collision(i)
		var collider := collision.get_collider()
		if collider is RigidBody2D:
			if collider.freeze:
				continue  # bloc pas poussable actuellement (joueur trop petit)
			var push_direction := -collision.get_normal()
			collider.apply_central_impulse(push_direction * push_force)
"

